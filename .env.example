# GitHub App Configuration
GITHUB_APP_ID=2469635
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# LLM Configuration (OpenRouter-compatible API)
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE_URL=https://your-api-url.com/v1
LLM_MODEL=eliza-Internal-DeepSeek-V3-1-Terminus
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000
LLM_TIMEOUT=180

# Server Configuration
PORT=8002
HOST=0.0.0.0
DEBUG=False

# Review Configuration
MAX_FILES_FOR_FULL_REVIEW=20
MAX_LINES_FOR_FULL_REVIEW=800
MAX_INLINE_COMMENTS=10
SKIP_DRAFT_PRS=True
